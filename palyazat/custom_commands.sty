\usepackage{titlesec}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% customize section and subsection style %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% SECTION -> NO NUMBER
\titleformat{\section}%
  {\large\bfseries}
  {}                % <- nincs számozás
  {0pt}
  {}

% SUBSECTION -> 1, 2, 3...
\renewcommand{\thesubsection}{\arabic{subsection}}

\titleformat{\subsection}%
  {\normalsize\bfseries}
  {\thesubsection}
  {0.5em}
  {}

\newcommand{\ts}{\textsuperscript}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newcommand{\blocktitle}[1]{\medskip\noindent\textbf{#1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
