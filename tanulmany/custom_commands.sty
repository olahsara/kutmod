\usepackage{titlesec}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% customize section and subsection style %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% SECTION -> 1
\titleformat{\section}%
  {\large\bfseries}   % méret + félkövér
  {\thesection}       % számozás
  {0.5em}             % távolság
  {}

% SUBSECTION -> 1.1
\titleformat{\subsection}%
  {\normalsize\bfseries}
  {\thesubsection}
  {0.5em}
  {}

\newcommand{\ts}{\textsuperscript} %sobrescrito 

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%